<script>
    document.addEventListener("DOMContentLoaded", function() {
        tinymce.init({
            selector: '#tinymce-editor', 
            height: 500, 
            plugins: 'table image link lists code',
            toolbar: 'undo redo | blocks | bold italic underline | alignleft aligncenter alignright alignjustify | bullist numlist | table insertAuditTable | link image customFileBtn | code',
            menubar: false, branding: false, promotion: false,
            table_toolbar: 'tableprops tabledelete | tableinsertrowbefore tableinsertrowafter tabledeleterow | tableinsertcolbefore tableinsertcolafter tabledeletecol | tablecellbackgroundcolor tablecellbordercolor',
            content_style: "body { font-family:Inter,sans-serif; font-size:14px } td, th { vertical-align: top !important; }",
            
            images_upload_handler: function (blobInfo, progress) {
                return new Promise((resolve, reject) => {
                    var reader = new FileReader();
                    reader.readAsDataURL(blobInfo.blob());
                    reader.onload = function () {
                        var base64data = reader.result;
                        google.script.run
                        .withSuccessHandler(function(url) { resolve(url); })
                        .withFailureHandler(function(error) { reject('Upload failed: ' + error.message); })
                        .uploadMediaToDrive(base64data, blobInfo.filename(), true);
                    };
                    reader.onerror = function() { reject('Image format error'); }
                });
            },
            setup: function (editor) {
                editor.ui.registry.addButton('insertAuditTable', {
                    icon: 'new-document',
                    tooltip: 'แทรกตาราง Audit หัว 2 ชั้น',
                    onAction: function () {
                        var tableTemplate = `
                        <table style="width: 100%; border-collapse: collapse; text-align: center; font-family: 'Inter', sans-serif;" border="1">
                            <thead>
                                <tr style="background-color: #0033a0; color: #ffffff;">
                                    <th rowspan="2" style="width: 8%; padding: 12px; border: 1px solid #444;">No.</th>
                                    <th rowspan="2" style="width: 42%; padding: 12px; border: 1px solid #444;">Audit Checklist / Detail</th>
                                    <th colspan="2" style="width: 30%; padding: 8px; border: 1px solid #444;">Evaluation Result</th>
                                    <th rowspan="2" style="width: 20%; padding: 12px; border: 1px solid #444;">Remarks / Note</th>
                                </tr>
                                <tr style="background-color: #e9ecef; color: #333333;">
                                    <th style="width: 15%; padding: 8px; border: 1px solid #444;">Status (Pass/Fail)</th>
                                    <th style="width: 15%; padding: 8px; border: 1px solid #444;">Score</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td style="padding: 10px; border: 1px solid #ccc;">1</td>
                                    <td style="text-align: left; padding: 10px; border: 1px solid #ccc;">รายละเอียดการตรวจสอบรายการที่ 1...</td>
                                    <td style="padding: 10px; border: 1px solid #ccc;"></td>
                                    <td style="padding: 10px; border: 1px solid #ccc;"></td>
                                    <td style="padding: 10px; border: 1px solid #ccc;"></td>
                                </tr>
                                <tr>
                                    <td style="padding: 10px; border: 1px solid #ccc;">2</td>
                                    <td style="text-align: left; padding: 10px; border: 1px solid #ccc;">รายละเอียดการตรวจสอบรายการที่ 2...</td>
                                    <td style="padding: 10px; border: 1px solid #ccc;"></td>
                                    <td style="padding: 10px; border: 1px solid #ccc;"></td>
                                    <td style="padding: 10px; border: 1px solid #ccc;"></td>
                                </tr>
                            </tbody>
                        </table><p><br></p>`;
                        editor.insertContent(tableTemplate);
                    }
                });

                editor.ui.registry.addButton('customFileBtn', {
                    icon: 'upload',
                    tooltip: 'Upload Document / File',
                    onAction: function () {
                        var input = document.createElement('input');
                        input.setAttribute('type', 'file');
                        input.onchange = function () {
                            var file = this.files[0];
                            if (!file) return;
                            showToast("Uploading file to document...", "bg-dark");
                            var reader = new FileReader();
                            reader.readAsDataURL(file);
                            reader.onload = function () {
                                google.script.run.withSuccessHandler(function(url) {
                                    var linkHtml = `<a href="${url}" target="_blank" rel="noopener noreferrer" contenteditable="false" style="background-color: #e0f2fe; border: 1px solid #7dd3fc; color: #0369a1; padding: 4px 12px; border-radius: 20px; font-size: 0.9em; font-weight: 600; display: inline-block; cursor: pointer; margin: 2px 4px; vertical-align: middle; text-decoration: none;" title="View Attached File">📎 ${file.name}</a>&nbsp;`;
                                    editor.insertContent(linkHtml);
                                    showToast("File inserted successfully!", "bg-success");
                                }).withFailureHandler(function(error) {
                                    alert("Upload failed: " + error.message);
                                }).uploadMediaToDrive(reader.result, file.name, false);
                            };
                        };
                        input.click();
                    }
                });
            }
        });
    });

    document.addEventListener('focusin', function(e) {
        if (e.target.closest('.tox-tinymce-aux, .moxman-window, .tam-assetmanager-root') !== null) { e.stopImmediatePropagation(); }
    });

    window.uiState01 = { years: {}, customers: {}, sessions: {} };
    window.uiState02 = { years: {}, customers: {}, sessions: {} };
    window.uiState03 = { years: {}, customers: {}, sessions: {} };
    window.currentData01 = null; window.currentData02 = null; window.currentData03 = null;
    const docTypesList = [ "1. Plant Tour information", "2. Audit Time Table", "3. Audit Preparation Material", "4. Audit Report (Customer)", "5. Audit Report (Internal)" ];

    function showToast(msg, bgClass = 'bg-dark') { 
        var toastEl = document.getElementById('statusToast'); toastEl.className = 'toast align-items-center text-white border-0 ' + bgClass;
        document.getElementById('toastMessage').innerHTML = `<i class="bi bi-info-circle"></i> ` + msg; new bootstrap.Toast(toastEl, {delay: 3000}).show();
    }

    function goBackToMenu() { 
        document.getElementById('customAuditPage').style.display = 'none'; 
        document.getElementById('auditResultPage').style.display = 'none'; 
        document.getElementById('materialAuditPage').style.display = 'none';
        document.getElementById('mainMenuPage').style.display = 'block';
    }

    function openPage(pageId) { 
        document.getElementById('mainMenuPage').style.display = 'none'; 
        document.getElementById('customAuditPage').style.display = 'none'; 
        document.getElementById('auditResultPage').style.display = 'none'; 
        document.getElementById('materialAuditPage').style.display = 'none'; 
        document.getElementById(pageId).style.display = 'block';
        if(pageId === 'customAuditPage') { loadData01(); } 
        else if(pageId === 'auditResultPage') { loadData02(); }
        else if(pageId === 'materialAuditPage') { loadData03(); }
    }

    function isExp(stateObj, key) { return stateObj[key] !== false; }

    function tog(mode, type, key) { 
        if(mode==='01') { window.uiState01[type][key] = !isExp(window.uiState01[type], key); renderTable01(window.currentData01); } 
        else if (mode==='02') { window.uiState02[type][key] = !isExp(window.uiState02[type], key); renderTable02(window.currentData02); }
        else if (mode==='03') { window.uiState03[type][key] = !isExp(window.uiState03[type], key); renderTable03(window.currentData03); }
    }

    // ==========================================
    // 🌟 RENDER 01 (Custom Audit)
    // ==========================================
    function loadData01() { google.script.run.withSuccessHandler(data => { window.currentData01 = data; renderTable01(data); }).getCustomAuditData(); }
    
    function renderTable01(data) {
        var tbody = document.getElementById('tableBody_01');
        if (!data || data.length === 0) { tbody.innerHTML = `<tr><td colspan="4" class="text-center text-muted py-5"><i class="bi bi-inbox fs-1"></i><br><strong>No Custom Documents</strong></td></tr>`; return; }
        var tree = {}; var rootNodes = [];
        data.forEach(function(row) {
            var ts=row[0], year=row[1], cust=row[2], aId=row[3], title=row[4], content=row[5], by=row[6], rName=row[7], status=row[8], pId=row[9];
            if (!aId) return;
            var node = { aId, title, content, by, rName, status, ts, children: [] };
            if (!pId || pId.trim() === "") { rootNodes.push(node); } else { if (!tree[pId]) tree[pId] = []; tree[pId].push(node); }
        });
        function attachChildren(nodes) { nodes.forEach(node => { if (tree[node.aId]) { node.children = tree[node.aId]; attachChildren(node.children); } }); }
        attachChildren(rootNodes);
        var html = '';
        function buildTreeHtml(nodes, level) {
            nodes.forEach(node => {
                var padding = 20 + (level * 40); var hasChildren = node.children.length > 0;
                var isExpanded = isExp(window.uiState01.sessions, node.aId); 
                var icon = hasChildren ? (isExpanded ? 'chevron-down text-dark fw-bold' : 'chevron-right text-dark fw-bold') : 'dash text-muted';
                var isCompleted = node.status === "Completed" && node.content !== "";
                var statusBadge = isCompleted ? `<span class="badge bg-success"><i class="bi bi-check-circle"></i> Completed</span>` : `<span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Draft</span>`;
                var safeContent = isCompleted ? encodeURIComponent(node.content) : "";
                var bgClass = level === 0 ? 'bg-light' : '';

                html += `
                <tr class="row-document hover-highlight ${bgClass}" onclick="if(${hasChildren}) { tog('01', 'sessions', '${node.aId}'); }">
                    <td class="text-start" style="padding-left: ${padding}px; border-left: ${level > 0 ? '2px dashed #dee2e6' : 'none'};">
                        <span style="cursor: ${hasChildren ? 'pointer' : 'default'}"><i class="bi bi-${icon} me-2"></i></span>
                        <i class="bi bi-file-earmark-richtext text-info fs-5 align-middle me-1"></i> 
                        <strong class="text-dark fs-6">${node.title}</strong>
                        <button class="btn btn-sm btn-link text-secondary p-0 ms-2" onclick="event.stopPropagation(); editCustomTitle('${node.aId}', '${node.title}')" title="Edit Title"><i class="bi bi-pencil"></i></button>
                        <br><small class="text-muted" style="margin-left: 35px;"><i class="bi bi-person text-secondary"></i> ${node.rName || '-'}</small>
                    </td>
                    <td class="text-center align-middle">${statusBadge}</td>
                    <td class="text-center align-middle" style="font-size: 0.85em; color: #6c757d;">${node.ts || '-'}<br>${node.by}</td>
                    <td class="text-center align-middle">
                        <button class="btn btn-sm btn-outline-success me-1 shadow-sm" onclick="event.stopPropagation(); openAddSessionModal('01', '${node.aId}')" title="Add Sub Document"><i class="bi bi-plus-circle"></i> Sub</button>
                        ${isCompleted ? `<button class="btn btn-outline-primary btn-sm me-1 shadow-sm" onclick="event.stopPropagation(); viewDocument('${safeContent}')"><i class="bi bi-eye"></i> View</button>` : ''}
                        <button class="btn btn-info btn-sm text-white fw-bold shadow-sm" onclick="event.stopPropagation(); openEditor('01', '${node.aId}', '${node.title}', '${safeContent}')"><i class="bi bi-pencil-square"></i> Edit</button>
                        <button class="btn btn-outline-danger btn-sm ms-1 shadow-sm" onclick="event.stopPropagation(); deleteSess('01', '${node.aId}')"><i class="bi bi-trash"></i></button>
                    </td>
                </tr>`;
                if (hasChildren && isExpanded) { buildTreeHtml(node.children, level + 1); }
            });
        }
        if (rootNodes.length > 0) { buildTreeHtml(rootNodes, 0); } 
        else { html = `<tr><td colspan="4" class="text-center text-muted py-5"><i class="bi bi-inbox fs-1"></i><br><strong>No Custom Documents</strong></td></tr>`; }
        tbody.innerHTML = html;
    }

    function editCustomTitle(aId, oldTitle) {
        var newTitle = prompt("Enter new document title:", oldTitle);
        if (newTitle && newTitle !== oldTitle) { showToast("Updating title...", "bg-dark"); google.script.run.withSuccessHandler(msg => { showToast(msg, "bg-success"); loadData01(); }).renameCustomDocTitle(aId, newTitle); }
    }

    // ==========================================
    // 🌟 RENDER 03 (Audit Material - Tree Structure)
    // ==========================================
    function loadData03() { google.script.run.withSuccessHandler(data => { window.currentData03 = data; renderTable03(data); }).getMaterialAuditData(); }
    
    function renderTable03(data) {
        var tbody = document.getElementById('tableBody_03');
        if (!data || data.length === 0) { tbody.innerHTML = `<tr><td colspan="4" class="text-center text-muted py-5"><i class="bi bi-inbox fs-1"></i><br><strong>No Material Documents</strong></td></tr>`; return; }
        var tree = {}; var rootNodes = [];
        data.forEach(function(row) {
            var ts=row[0], year=row[1], cust=row[2], aId=row[3], title=row[4], content=row[5], by=row[6], rName=row[7], status=row[8], pId=row[9];
            if (!aId) return;
            var node = { aId, title, content, by, rName, status, ts, children: [] };
            if (!pId || pId.trim() === "") { rootNodes.push(node); } else { if (!tree[pId]) tree[pId] = []; tree[pId].push(node); }
        });
        function attachChildren(nodes) { nodes.forEach(node => { if (tree[node.aId]) { node.children = tree[node.aId]; attachChildren(node.children); } }); }
        attachChildren(rootNodes);
        var html = '';
        function buildTreeHtml(nodes, level) {
            nodes.forEach(node => {
                var padding = 20 + (level * 40); var hasChildren = node.children.length > 0;
                var isExpanded = isExp(window.uiState03.sessions, node.aId); 
                var icon = hasChildren ? (isExpanded ? 'chevron-down text-dark fw-bold' : 'chevron-right text-dark fw-bold') : 'dash text-muted';
                var isCompleted = node.status === "Completed" && node.content !== "";
                var statusBadge = isCompleted ? `<span class="badge bg-success"><i class="bi bi-check-circle"></i> Completed</span>` : `<span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Draft</span>`;
                var safeContent = isCompleted ? encodeURIComponent(node.content) : "";
                var bgClass = level === 0 ? 'bg-light' : '';

                html += `
                <tr class="row-document hover-highlight ${bgClass}" onclick="if(${hasChildren}) { tog('03', 'sessions', '${node.aId}'); }">
                    <td class="text-start" style="padding-left: ${padding}px; border-left: ${level > 0 ? '2px dashed #dee2e6' : 'none'};">
                        <span style="cursor: ${hasChildren ? 'pointer' : 'default'}"><i class="bi bi-${icon} me-2"></i></span>
                        <i class="bi bi-file-earmark-richtext text-secondary fs-5 align-middle me-1"></i> 
                        <strong class="text-dark fs-6">${node.title}</strong>
                        <button class="btn btn-sm btn-link text-secondary p-0 ms-2" onclick="event.stopPropagation(); editMaterialTitle('${node.aId}', '${node.title}')" title="Edit Title"><i class="bi bi-pencil"></i></button>
                        <br><small class="text-muted" style="margin-left: 35px;"><i class="bi bi-person text-secondary"></i> ${node.rName || '-'}</small>
                    </td>
                    <td class="text-center align-middle">${statusBadge}</td>
                    <td class="text-center align-middle" style="font-size: 0.85em; color: #6c757d;">${node.ts || '-'}<br>${node.by}</td>
                    <td class="text-center align-middle">
                        <button class="btn btn-sm btn-outline-success me-1 shadow-sm" onclick="event.stopPropagation(); openAddSessionModal('03', '${node.aId}')" title="Add Sub Document"><i class="bi bi-plus-circle"></i> Sub</button>
                        ${isCompleted ? `<button class="btn btn-outline-primary btn-sm me-1 shadow-sm" onclick="event.stopPropagation(); viewDocument('${safeContent}')"><i class="bi bi-eye"></i> View</button>` : ''}
                        <button class="btn btn-secondary btn-sm text-white fw-bold shadow-sm" onclick="event.stopPropagation(); openEditor('03', '${node.aId}', '${node.title}', '${safeContent}')"><i class="bi bi-pencil-square"></i> Edit</button>
                        <button class="btn btn-outline-danger btn-sm ms-1 shadow-sm" onclick="event.stopPropagation(); deleteSess('03', '${node.aId}')"><i class="bi bi-trash"></i></button>
                    </td>
                </tr>`;
                if (hasChildren && isExpanded) { buildTreeHtml(node.children, level + 1); }
            });
        }
        if (rootNodes.length > 0) { buildTreeHtml(rootNodes, 0); } 
        else { html = `<tr><td colspan="4" class="text-center text-muted py-5"><i class="bi bi-inbox fs-1"></i><br><strong>No Material Documents</strong></td></tr>`; }
        tbody.innerHTML = html;
    }

    function editMaterialTitle(aId, oldTitle) {
        var newTitle = prompt("Enter new document title:", oldTitle);
        if (newTitle && newTitle !== oldTitle) { showToast("Updating title...", "bg-dark"); google.script.run.withSuccessHandler(msg => { showToast(msg, "bg-success"); loadData03(); }).renameMaterialDocTitle(aId, newTitle); }
    }

    // ==========================================
    // 🌟 EDITOR & VIEW FUNCTIONS 
    // ==========================================
    function openEditor(mode, aId, title, safeContentStr) {
        document.getElementById('editDocMode').value = mode;
        document.getElementById('editDocAuditId').value = aId;
        document.getElementById('editorDocTitleDisplay').innerText = title;
        var htmlContent = safeContentStr ? decodeURIComponent(safeContentStr) : "";
        var editor = tinymce.get('tinymce-editor');
        if (editor) {
            editor.setContent(htmlContent);
            editor.undoManager.clear();
        }
        var myModal = new bootstrap.Modal(document.getElementById('editorModal'));
        myModal.show();
    }
    
    function saveRichDocument() {
        var mode = document.getElementById('editDocMode').value;
        var aId = document.getElementById('editDocAuditId').value;
        var contentHTML = tinymce.get('tinymce-editor').getContent(); 
        var textOnly = contentHTML.replace(/<[^>]*>?/gm, '').trim();
        var hasImage = contentHTML.includes('<img');
        if(textOnly === "" && !hasImage) return alert("Document is empty!");

        var btn = document.getElementById('btnSaveRichDoc');
        btn.innerHTML = '<i class="bi bi-arrow-repeat spin"></i> Saving...'; btn.disabled = true;
        showToast("Saving document...", "bg-dark");
        
        var onSuccess = msg => {
            bootstrap.Modal.getInstance(document.getElementById('editorModal')).hide();
            btn.innerHTML = '<i class="bi bi-save"></i> Save Document'; btn.disabled = false;
            showToast(msg, "bg-success"); 
            if (mode === '01') { loadData01(); } else if (mode === '03') { loadData03(); }
        };
        var onFailure = err => {
            btn.innerHTML = '<i class="bi bi-save"></i> Save Document'; btn.disabled = false;
            showToast("Failed to save!", "bg-danger"); alert("Failed to save:\n" + err.message);
        };

        if (mode === '01') {
            google.script.run.withSuccessHandler(onSuccess).withFailureHandler(onFailure).saveCustomDocContent(aId, contentHTML);
        } else if (mode === '03') {
            google.script.run.withSuccessHandler(onSuccess).withFailureHandler(onFailure).saveMaterialDocContent(aId, contentHTML);
        }
    }

    function viewDocument(safeContentStr) {
        var htmlContent = decodeURIComponent(safeContentStr);
        document.getElementById('docViewer').innerHTML = htmlContent; 
        new bootstrap.Modal(document.getElementById('viewDocModal')).show();
    }

    // ==========================================
    // 🌟 RENDER 02 (Audit Result)
    // ==========================================
    function loadData02() { google.script.run.withSuccessHandler(data => { window.currentData02 = data; renderTable02(data); }).getAuditData(); }
    function renderTable02(data) {
        var tbody = document.getElementById('tableBody_02'); var groupedData = {};
        if (data && data.length > 0) {
            data.forEach(function(row) {
                var ts=row[0], year=row[1], cust=row[2], aId=row[3], doc=row[4], fName=row[5], fLink=row[6], by=row[7], rName=row[8], detail=row[9];
                if (!year || !cust || !aId) return; 
                if (!groupedData[year]) groupedData[year] = {}; if (!groupedData[year][cust]) groupedData[year][cust] = {};
                if (!groupedData[year][cust][aId]) { groupedData[year][cust][aId] = { lastEdit: ts, contactName: rName, docs: {} }; docTypesList.forEach(dt => groupedData[year][cust][aId].docs[dt] = []); }
                if(fName && fLink && doc) groupedData[year][cust][aId].docs[doc].push({ fileName: fName, fileLink: fLink, timestamp: ts, actionBy: by, fileDetail: detail });
            });
        }
        var years = Object.keys(groupedData).sort((a, b) => parseInt(a) - parseInt(b));
        if (years.length === 0) { tbody.innerHTML = `<tr><td colspan="4" class="text-center text-muted py-5"><i class="bi bi-inbox fs-1"></i><br><strong>No Upload Data</strong></td></tr>`; return; }

        var html = '';
        years.forEach(function(year) {
            let isYOpen = isExp(window.uiState02.years, year);
            html += `<tr class="row-year" onclick="tog('02', 'years', '${year}')"><td colspan="4" class="ps-3"><i class="bi bi-chevron-${isYOpen?'down':'right'}"></i> &nbsp; Year ${year}</td></tr>`;
            if(isYOpen) {
                var customers = Object.keys(groupedData[year]).sort();
                customers.forEach(function(cust) {
                    let custKey = year + '_' + cust; let isCOpen = isExp(window.uiState02.customers, custKey);
                    var firstAuditId = Object.keys(groupedData[year][cust])[0];
                    var contactName = firstAuditId ? groupedData[year][cust][firstAuditId].contactName : '-';
                    html += `<tr class="row-customer" onclick="tog('02', 'customers', '${custKey}')"><td colspan="4" class="ps-4"><div class="d-flex justify-content-between align-items-center"><span><i class="bi bi-chevron-${isCOpen?'down':'right'}"></i> &nbsp; <i class="bi bi-building"></i> Customer: ${cust} <span class="text-secondary ms-2 fw-normal" style="font-size: 0.85em;">(Contact: ${contactName || '-'})</span></span><div><button class="btn btn-sm btn-outline-secondary me-1" onclick="event.stopPropagation(); openEditCustomerModal('${cust}')"><i class="bi bi-pencil-square"></i> Edit Name</button></div></div></td></tr>`;
                    if(isCOpen) {
                        var auditIds = Object.keys(groupedData[year][cust]).sort().reverse();
                        auditIds.forEach(function(aId) {
                            let isSOpen = isExp(window.uiState02.sessions, aId);
                            var sessData = groupedData[year][cust][aId];
                            var lastActive = sessData.lastEdit ? sessData.lastEdit : '-'; var justDate = lastActive !== '-' ? lastActive.split(' ')[0] : '-';
                            html += `<tr class="row-audit-tag" onclick="tog('02', 'sessions', '${aId}')"><td colspan="3" class="ps-5"><div class="d-flex flex-column py-2"><span><i class="bi bi-chevron-${isSOpen?'down':'right'} fw-bold"></i> &nbsp; <i class="bi bi-building text-corporate"></i> <strong>${cust}</strong> <span class="text-muted ms-2" style="font-size: 0.9em;"><i class="bi bi-calendar-event"></i> Date: ${justDate}</span></span></div></td><td class="text-center align-middle"><button class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation(); deleteSess('02', '${aId}')"><i class="bi bi-trash"></i></button></td></tr>`;
                            if(isSOpen) {
                                docTypesList.forEach(function(dt) {
                                    var files = sessData.docs[dt] || [];
                                    html += `<tr class="row-document"><td colspan="3" class="ps-5 fw-bold text-dark" style="padding-left: 5rem !important;"><i class="bi bi-folder2-open text-corporate"></i> ${dt}</td><td class="text-center"><button class="btn btn-sm btn-outline-corporate fw-bold" onclick="event.stopPropagation(); openUploadModal('${year}', '${cust}', '${aId}', '${dt}')"><i class="bi bi-upload"></i> Upload</button></td></tr>`;
                                    if (files.length === 0) { html += `<tr class="text-center row-document"><td colspan="4" class="text-secondary small py-2">- No file -</td></tr>`; } 
                                    else {
                                        files.forEach(function(f) {
                                            var dateDisplay = f.timestamp ? f.timestamp : '-'; var escapedDetail = f.fileDetail ? f.fileDetail.replace(/'/g, "\\'") : '';
                                            html += `<tr class="text-center row-document"><td class="text-start" style="padding-left: 6.5rem !important; width: 40%;"><span class="text-dark small">${f.fileDetail || '-'}</span> <button class="btn btn-link btn-sm p-0 ms-2 text-secondary" onclick="event.stopPropagation(); openEditDetailModal('${aId}', '${dt}', '${f.fileLink}', '${escapedDetail}')" title="Edit Detail"><i class="bi bi-pencil-square"></i></button></td><td><span onclick="window.open('${f.fileLink}', '_blank')" class="file-link" style="cursor: pointer;" title="Click to view document"><i class="bi bi-file-earmark-check text-success"></i> ${f.fileName}</span></td><td style="font-size: 0.85em; color: #6c757d;">${dateDisplay}<br><i class="bi bi-person text-secondary"></i> <span class="text-primary">${f.actionBy || '-'}</span></td><td><button class="btn btn-outline-danger btn-upload-sm ms-1" onclick="event.stopPropagation(); removeFile('${aId}', '${dt}', '${f.fileLink}')"><i class="bi bi-trash"></i></button></td></tr>`;
                                        });
                                    }
                                });
                            }
                        });
                    }
                });
            }
        });
        tbody.innerHTML = html;
    }

    // ==========================================
    // SHARED FUNCTIONS 
    // ==========================================
    function openAddSessionModal(mode, parentId = "") { 
        document.getElementById('sysMode').value = mode;
        document.getElementById('sysParentId').value = parentId; 
        
        if (parentId !== "") { document.getElementById('addSessionTitle').innerHTML = '<i class="bi bi-diagram-3"></i> Add Sub-Document'; } 
        else {
            if(mode === '01') document.getElementById('addSessionTitle').innerHTML = '<i class="bi bi-file-earmark-plus"></i> New Main Document';
            else if (mode === '03') document.getElementById('addSessionTitle').innerHTML = '<i class="bi bi-box-seam"></i> New Material Document';
            else document.getElementById('addSessionTitle').innerHTML = '<i class="bi bi-cloud-arrow-up"></i> New Upload Session';
        }

        document.getElementById('sysYear').value = new Date().getFullYear();
        if (mode === '01' || mode === '03') {
            document.getElementById('sysYearCustomerContainer').style.display = 'none';
            document.getElementById('sysDocTitleContainer').style.display = 'block';
            document.getElementById('btnCreateSessionContinue').style.display = 'none';
        } else {
            document.getElementById('sysYearCustomerContainer').style.display = 'block';
            document.getElementById('sysDocTitleContainer').style.display = 'none';
            document.getElementById('btnCreateSessionContinue').style.display = 'block';
        }
        new bootstrap.Modal(document.getElementById('addSessionModal')).show();
    }

    function executeCreateSession(keepOpen) { 
        var mode = document.getElementById('sysMode').value;
        var pId = document.getElementById('sysParentId').value; 
        var y = document.getElementById('sysYear').value || "2026", c = document.getElementById('sysCustomer').value || "Default", r = document.getElementById('sysContact').value;
        var dTitle = document.getElementById('sysDocTitle').value;
        
        if(!r) return alert("Please fill in Contact Person.");
        if((mode === '01' || mode === '03') && !dTitle) return alert("Please enter a Document Title."); 
        
        var btnId = keepOpen ? 'btnCreateSessionContinue' : 'btnCreateSession';
        var btn = document.getElementById(btnId); var originalText = btn.innerHTML;
        btn.innerHTML = '<i class="bi bi-arrow-repeat spin"></i>'; btn.disabled = true; showToast("Creating...", "bg-dark");
        
        if(mode === '01') { 
            google.script.run.withSuccessHandler(msg => { finishCreateSess(msg, keepOpen, originalText, btnId); loadData01(); }).createNewCustomSession(y, c, r, dTitle, pId);
        } else if (mode === '03') {
            google.script.run.withSuccessHandler(msg => { finishCreateSess(msg, keepOpen, originalText, btnId); loadData03(); }).createNewMaterialSession(y, c, r, dTitle, pId);
        } else { 
            google.script.run.withSuccessHandler(msg => { finishCreateSess(msg, keepOpen, originalText, btnId); loadData02(); }).createNewCustomerFolders(y, c, r);
        } 
    }

    function finishCreateSess(msg, keepOpen, originalText, btnId) { 
        if(!keepOpen) { bootstrap.Modal.getInstance(document.getElementById('addSessionModal')).hide(); document.getElementById('sysCustomer').value = ""; }
        document.getElementById('sysContact').value = ""; document.getElementById('sysDocTitle').value = ""; 
        var btn = document.getElementById(btnId); btn.innerHTML = originalText; btn.disabled = false; 
        showToast(msg, "bg-success");
    }

    function openEditDetailModal(aId, type, link, currentDetail) { document.getElementById('editDetailAuditId').value = aId; document.getElementById('editDetailDocType').value = type; document.getElementById('editDetailFileLink').value = link; document.getElementById('editDetailInput').value = currentDetail; new bootstrap.Modal(document.getElementById('editDetailModal')).show(); }
    function saveEditDetail() { var aId = document.getElementById('editDetailAuditId').value; var type = document.getElementById('editDetailDocType').value; var link = document.getElementById('editDetailFileLink').value; var detail = document.getElementById('editDetailInput').value; document.getElementById('btnSaveDetail').innerHTML = '<i class="bi bi-arrow-repeat spin"></i>'; document.getElementById('btnSaveDetail').disabled = true; showToast("Updating detail...", "bg-dark"); google.script.run.withSuccessHandler(msg => { bootstrap.Modal.getInstance(document.getElementById('editDetailModal')).hide(); document.getElementById('btnSaveDetail').innerHTML = 'Save Detail'; document.getElementById('btnSaveDetail').disabled = false; showToast(msg, "bg-success"); loadData02(); }).editFileDetail(aId, type, link, detail); }
    function deleteSess(mode, aId) { 
        if(confirm("Permanently delete this?")) { 
            showToast("Deleting...", "bg-danger");
            if(mode === '01') { google.script.run.withSuccessHandler(msg => { showToast(msg, "bg-success"); loadData01(); }).deleteCustomSession(aId); } 
            else if (mode === '03') { google.script.run.withSuccessHandler(msg => { showToast(msg, "bg-success"); loadData03(); }).deleteMaterialSession(aId); }
            else { google.script.run.withSuccessHandler(msg => { showToast(msg, "bg-success"); loadData02(); }).deleteAuditSession(aId); } 
        } 
    }
    function openUploadModal(y, c, aId, type) { document.getElementById('uploadYear').value = y; document.getElementById('uploadCustomer').value = c; document.getElementById('uploadAuditId').value = aId; document.getElementById('uploadDocType').value = type; document.getElementById('uploadDetail').value = ""; document.getElementById('fileInput').value = ""; document.getElementById('fileNameDisplay').value = ""; new bootstrap.Modal(document.getElementById('uploadModal')).show(); }
    function uploadFile() { var fInput = document.getElementById('fileInput'); if(fInput.files.length===0) return alert("Please select a file."); var y = document.getElementById('uploadYear').value, c = document.getElementById('uploadCustomer').value, aId = document.getElementById('uploadAuditId').value, type = document.getElementById('uploadDocType').value, detail = document.getElementById('uploadDetail').value; var folderId = "11eTo7X-xeLe7WGnPOyNnF4_DS8qNkPbf"; var f = fInput.files[0], reader = new FileReader(); document.getElementById('btnSaveFile').innerHTML = '<i class="bi bi-arrow-repeat spin"></i>'; document.getElementById('btnSaveFile').disabled = true; showToast("Uploading...", "bg-dark"); reader.onload = e => { google.script.run.withSuccessHandler(msg => { bootstrap.Modal.getInstance(document.getElementById('uploadModal')).hide(); document.getElementById('btnSaveFile').innerHTML = 'Save File'; document.getElementById('btnSaveFile').disabled = false; document.getElementById('uploadDetail').value = ""; document.getElementById('fileInput').value = ""; document.getElementById('fileNameDisplay').value = ""; showToast(msg, "bg-success"); loadData02(); }).uploadFileToDrive(e.target.result, f.name, y, c, aId, type, folderId, detail); }; reader.readAsDataURL(f); }
    function removeFile(aId, type, link) { if(confirm("Delete this file?")) { showToast("Deleting...", "bg-danger"); google.script.run.withSuccessHandler(msg => { showToast(msg, "bg-success"); loadData02(); }).removeFileFromSheet(aId, type, link); } }
    function openEditCustomerModal(c) { document.getElementById('oldCustomerName').value = c; document.getElementById('renameCustomerInput').value = c; new bootstrap.Modal(document.getElementById('editCustomerModal')).show(); }
    function saveEditCustomer() { var oldC = document.getElementById('oldCustomerName').value, newC = document.getElementById('renameCustomerInput').value; if(newC===""||newC===oldC) return; document.getElementById('btnEditCustomer').innerHTML = '<i class="bi bi-arrow-repeat spin"></i>'; document.getElementById('btnEditCustomer').disabled = true; showToast("Updating data...", "bg-dark"); google.script.run.withSuccessHandler(msg => { bootstrap.Modal.getInstance(document.getElementById('editCustomerModal')).hide(); document.getElementById('btnEditCustomer').innerHTML = 'Save'; document.getElementById('btnEditCustomer').disabled = false; showToast(msg, "bg-success"); loadData01(); loadData02(); loadData03(); }).renameCustomerInSheet(oldC, newC); }

   

</script>
